@echo off
echo Starting Native Server on port 8080...
powershell -NoProfile -ExecutionPolicy Bypass -Command "$port=8080; $listener = New-Object System.Net.HttpListener; $listener.Prefixes.Add('http://127.0.0.1:'+$port+'/'); $listener.Prefixes.Add('http://localhost:'+$port+'/'); $listener.Start(); Write-Host 'Server listening on http://127.0.0.1:8080' -ForegroundColor Green; Start-Process 'http://127.0.0.1:8080'; while($listener.IsListening){$context=$listener.GetContext(); $req=$context.Request; $res=$context.Response; $path=$req.Url.LocalPath; if($path -eq '/'){$path='/index.html'}; $file='C:\Users\acer\.gemini\antigravity\scratch\portfolio-website'+$path.Replace('/','\'); if(Test-Path $file -PathType Leaf){$bytes=[System.IO.File]::ReadAllBytes($file); $res.ContentType='text/html'; if($file.EndsWith('.css')){$res.ContentType='text/css'}elseif($file.EndsWith('.js')){$res.ContentType='application/javascript'}elseif($file.EndsWith('.jpg') -or $file.EndsWith('.jpeg')){$res.ContentType='image/jpeg'}elseif($file.EndsWith('.png')){$res.ContentType='image/png'}; $res.OutputStream.Write($bytes,0,$bytes.Length)}else{$res.StatusCode=404}; $res.Close()}"
